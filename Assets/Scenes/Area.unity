--- !u!114 &763315545
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 763315538}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9cfd4c13b79e5ce40862d646eb185caa, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  contenidoNota: "No s\xE9 cu\xE1nto tiempo me queda, as\xED que ser\xE9 breve. Algo
    est\xE1 pasando en esta costa\u2026 algo que no tendr\xEDa que existir.\nCuando
    llegu\xE9 a la d\xE1rsena de la fortaleza pens\xE9 que solo investigar\xEDa rumores
    de un asentamiento abandonado\u2026 pero las sombras aqu\xED parecen tener voluntad
    propia.\nLas luces se apagan sin raz\xF3n.\nLos pasos resuenan incluso cuando
    estoy sola.\nY por la noche, oigo un murmullo bajo las tablas del embarcadero,\ncomo
    si el mar susurrara mi nombre.\n\nEncontr\xE9 documentos. Fragmentos de diarios.
    Hablan de un descubrimiento que los antiguos guardias intentaron ocultar.\nNo
    s\xE9 qu\xE9 liberaron\u2026 pero a\xFAn sigue aqu\xED. Y creo que empieza a
    notar mi presencia.\n\nSi recibes esta carta, por favor\u2026 ven.\nNo conf\xEDo
    en nadie m\xE1s.\nAlgo en este lugar est\xE1 cambiando,\ny temo que pronto yo
    tambi\xE9n cambie con \xE9l.\nNo tardes, por favor.\n\u2014 Amy"
  panelVisorNota: {fileID: 1890742766}
  textoVisor: {fileID: 457360076}
  textoAviso: {fileID: 0}
  velocidadEscritura: 0.05
  audioEscritura: {fileID: 763315546}
